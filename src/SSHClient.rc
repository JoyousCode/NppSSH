#include "Resource.h"
#include <windows.h>

// 相对路径（RC 在 src/ 目录，图标在 src/res/，路径正确，直接保留）
IDI_ICON_CONNECT ICON "res/connect.ico"
IDI_ICON_DISCONNECT ICON "res/disconnect.ico"

// 严格按此样式定义，无WS_VISIBLE！
IDD_SSH_PANEL DIALOGEX 0, 0, 400, 300
STYLE DS_SETFONT | DS_FIXEDSYS | WS_CHILD | WS_BORDER
CAPTION "NppSSH Terminal"
FONT 9, "Microsoft Sans Serif", 400, 0, 0x1
BEGIN
    EDITTEXT IDC_OUTPUT_EDIT, 0, 0, 400, 300, ES_MULTILINE | ES_AUTOVSCROLL | ES_READONLY | WS_VSCROLL | WS_CHILD
END